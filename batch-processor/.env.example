# ── UNIFIED SERVICE TAGGING (required for Datadog correlation) ────────────────
# https://docs.datadoghq.com/getting_started/tagging/unified_service_tagging/
#
# These three tags must be set consistently across ALL telemetry signals
# (traces, logs, metrics, profiler) to enable Datadog's cross-signal correlation.
DD_ENV=staging                  # Propagates to all telemetry: traces, logs, metrics
DD_SERVICE=batch-processor      # Must match the service name in Docker Compose / K8s exactly
DD_VERSION=                     # Set to the container image tag in CI: $(git rev-parse --short HEAD)
                                # Ties every failed batch run to the exact commit that caused it

# ── AGENT CONNECTION ──────────────────────────────────────────────────────────
DD_AGENT_HOST=datadog-agent     # Docker Compose service name for the Datadog Agent container
                                # Override to 'localhost' for local non-Docker development
                                # In Kubernetes: not needed — agent auto-detected via DaemonSet

# ── TRACE SAMPLE RATE ─────────────────────────────────────────────────────────
# NOT commented out — batch jobs run infrequently and every run must be captured.
# Setting this to 1.0 ensures 100% of batch job traces reach Datadog, regardless
# of the global agent sampling configuration.
# Docs: https://docs.datadoghq.com/tracing/trace_pipeline/ingestion_mechanisms/
DD_TRACE_SAMPLE_RATE=1.0

# ── DATABASE ──────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-ledger:5432/ledger
SPRING_DATASOURCE_USERNAME=finance_batch
SPRING_DATASOURCE_PASSWORD=changeme   # Replace with a secret manager reference in production

# ── DATADOG INSTRUMENTATION ───────────────────────────────────────────────────
# Uncomment the JAVA_TOOL_OPTIONS block below after:
#   - Downloading dd-java-agent.jar in your Dockerfile (Step 3)
#   - Setting DD_ENV, DD_SERVICE, DD_VERSION above
#
# Each flag enables a specific observability layer. Enable incrementally
# following the Learning Progression in README.md.
#
# Step 3  — APM + auto-instrumentation (Spring Batch steps, JDBC, scheduler)
# Step 4  — Log correlation (injects dd.trace_id/dd.span_id into log MDC)
# Step 7  — Continuous Profiler (JVM CPU/heap flame graphs)
# Step 11 — Data Jobs Monitoring (batch job run history, step duration, records processed)
#
# JAVA_TOOL_OPTIONS="\
#   -javaagent:/dd-java-agent.jar \
#   -Ddd.service=${DD_SERVICE} \
#   -Ddd.env=${DD_ENV} \
#   -Ddd.version=${DD_VERSION} \
#   -Ddd.logs.injection=true \
#   -Ddd.data.jobs.enabled=true \
#   -Ddd.profiling.enabled=true \
#   -Ddd.runtime.metrics.enabled=true \
#   -Ddd.trace.sample.rate=1.0"
#
# Runtime metrics (JVM heap, GC pause time, thread count, class loading):
# DD_RUNTIME_METRICS_ENABLED=true   # Equivalent to -Ddd.runtime.metrics.enabled=true
# ─────────────────────────────────────────────────────────────────────────────

# ── DATA STREAMS MONITORING ───────────────────────────────────────────────────
# Enable if batch-processor publishes to JMS queues (e.g. alert.queue via
# notification-service after statement generation). DSM gives end-to-end
# pipeline visibility: producer latency, consumer lag, queue depth.
# Docs: https://docs.datadoghq.com/data_streams/
#
# DD_DATA_STREAMS_ENABLED=true
# DD_DATA_STREAMS_BUCKET_DURATION=10   # Aggregation window in seconds
# ─────────────────────────────────────────────────────────────────────────────

# ── CUSTOM FINANCE TAGS ───────────────────────────────────────────────────────
# Add these tags to every span and log for Finance-domain triage.
# Set via span.setTag() in DatadogJobListener (commented) or as process-level tags:
# DD_TAGS=region:eu-west-1,team:finance-ops,cost_centre:batch
# ─────────────────────────────────────────────────────────────────────────────
