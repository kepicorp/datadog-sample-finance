# ── UNIFIED SERVICE TAGGING (required for Datadog correlation) ────────
# These three variables tie every trace, log, metric, and profile to
# the same service entity in Datadog. Set them before starting the
# container or the Datadog Agent will not correlate telemetry correctly.
# Docs: https://docs.datadoghq.com/getting_started/tagging/unified_service_tagging/

DD_ENV=staging                   # Propagates to all telemetry: traces, logs, metrics, RUM
DD_SERVICE=fraud-detection       # Must match the Docker / K8s service name exactly
DD_VERSION=1.0.0                 # Tie deployments to anomalies via Deployment Tracking
                                 # In CI: DD_VERSION=$(git rev-parse --short HEAD)

# ── DATADOG AGENT CONNECTION ──────────────────────────────────────────
# Override to 'localhost' when running the Agent on the host directly.
# In Docker Compose / K8s this points to the sidecar or DaemonSet pod.
DD_AGENT_HOST=datadog-agent

# ── ACTIVEMQ / STOMP BROKER ───────────────────────────────────────────
STOMP_HOST=activemq-artemis
STOMP_PORT=61613
STOMP_USER=admin
STOMP_PASS=admin                 # Never hardcode credentials in production.
                                 # Use Docker secrets / K8s Secret / AWS Secrets Manager.
FRAUD_QUEUE=fraud.score.queue

# ── DATADOG DATA STREAMS MONITORING ───────────────────────────────────
# Uncomment to enable pipeline visibility for the JMS consumer.
# Exposes consumer lag, end-to-end latency, and queue depth in DSM.
# Docs: https://docs.datadoghq.com/data_streams/python/
#
# DD_DATA_STREAMS_ENABLED=true
# DD_DATA_STREAMS_BUCKET_DURATION=10   # Aggregation window in seconds

# ── DATADOG DOGSTATSD ─────────────────────────────────────────────────
# Required only if you uncomment the DogStatsD gauge in listener.py.
# Defaults to DD_AGENT_HOST:8125 if not set.
# Docs: https://docs.datadoghq.com/developers/dogstatsd/
#
# DOGSTATSD_HOST=datadog-agent
# DOGSTATSD_PORT=8125

# ── DATADOG APM SAMPLING ──────────────────────────────────────────────
# In production, set a sample rate below 1.0 to reduce trace volume.
# For this async consumer, 1.0 is recommended — messages are infrequent
# relative to HTTP services, so every scoring trace has value.
# Docs: https://docs.datadoghq.com/tracing/trace_pipeline/ingestion_controls/
#
# DD_TRACE_SAMPLE_RATE=1.0

# ── DATADOG RUNTIME METRICS ───────────────────────────────────────────
# Emits Python GC, memory, and thread metrics automatically.
# No code change needed — the ddtrace library handles this.
# Docs: https://docs.datadoghq.com/tracing/metrics/runtime_metrics/python/
#
# DD_RUNTIME_METRICS_ENABLED=true

# ── CUSTOM BUSINESS TAGS ──────────────────────────────────────────────
# Finance-domain tags added to every span for fast triage in APM.
# Uncomment and set values when enabling APM (Step 3+).
# HIGH-CARDINALITY WARNING: never use raw transaction IDs or message IDs
# as tag values. Docs: https://docs.datadoghq.com/tagging/assigning_tags/#defining-tags
#
# DD_CUSTOM_TAG_REGION=eu-west-1
# DD_CUSTOM_TAG_QUEUE=fraud.score.queue
