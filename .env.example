# ══════════════════════════════════════════════════════════════════════════════
# Finance Sample App — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# USAGE:
#   cp .env.example .env
#   # Edit .env with real values, then:
#   docker compose up --build
#
# SECURITY WARNING:
#   .env contains secrets. It MUST be listed in .gitignore and MUST NEVER be
#   committed to version control. The .env.example file (this file) is safe to
#   commit — it contains only placeholder values.
#
# ══════════════════════════════════════════════════════════════════════════════

# ── DATADOG CREDENTIALS ───────────────────────────────────────────────────────
# Get your API key from: https://app.datadoghq.com/organization-settings/api-keys
# The Agent will not start without a valid key. Leave blank to run the app
# without any telemetry (all instrumentation is commented out by default).
#
# SECURITY: Never hardcode this value in docker-compose.yml or any source file.
DD_API_KEY=REPLACE_WITH_YOUR_DD_API_KEY
DD_APP_KEY=REPLACE_WITH_YOUR_DD_APP_KEY

# Datadog site — change if your org is on EU or Gov:
#   datadoghq.com     (US1, default)
#   datadoghq.eu      (EU)
#   us3.datadoghq.com (US3)
#   us5.datadoghq.com (US5)
#   ddog-gov.com      (Gov)
DD_SITE=datadoghq.com

# ── UNIFIED SERVICE TAGGING ───────────────────────────────────────────────────
# These three tags correlate ALL telemetry (traces, logs, metrics, RUM) for a
# given deployment. Keep them consistent across every service.
# Docs: https://docs.datadoghq.com/getting_started/tagging/unified_service_tagging/
#
# DD_ENV propagates to all containers via docker-compose.yml environment blocks.
DD_ENV=staging

# DD_VERSION should match the container image tag. In CI, automate this:
#   DD_VERSION=$(git rev-parse --short HEAD)
DD_VERSION=1.0.0

# ── POSTGRESQL CREDENTIALS ────────────────────────────────────────────────────
# Used by: postgres-ledger, account-service, batch-processor
# SECURITY: Use a strong password. In production, inject via AWS Secrets Manager
# or GCP Secret Manager — never commit real credentials.
POSTGRES_USER=finance
POSTGRES_PASSWORD=REPLACE_WITH_SECRET

# Separate read-only user for Datadog DBM (Learning Progression Step 9).
# Create this user in PostgreSQL before enabling DBM:
#   CREATE USER datadog WITH PASSWORD '<value below>';
#   GRANT pg_monitor TO datadog;
# DATADOG_DBM_PASSWORD=REPLACE_WITH_DBM_SECRET

# ── ACTIVEMQ ARTEMIS CREDENTIALS ─────────────────────────────────────────────
# Used by: activemq-artemis, account-service, transaction-service,
#          fraud-detection, notification-service
ARTEMIS_USER=admin
ARTEMIS_PASSWORD=REPLACE_WITH_SECRET

# ── CUSTOM BUSINESS TAGS (add to every span and log) ─────────────────────────
# Finance-specific tags for fast triage. Set at deployment time and propagate
# via the application's DD_CUSTOM_TAGS or span tagging code.
# Docs: https://docs.datadoghq.com/tagging/assigning_tags/
#
# DD_CUSTOM_TAG_REGION=eu-west-1
# DD_CUSTOM_TAG_TRANSACTION_TYPE=payment
# DD_CUSTOM_TAG_ACCOUNT_TIER=premium

# ── DATA STREAMS MONITORING ───────────────────────────────────────────────────
# Uncomment when completing Learning Progression Step 10.
# Set on each application service that produces or consumes JMS messages.
# Docs: https://docs.datadoghq.com/data_streams/
#
# DD_DATA_STREAMS_ENABLED=true
# DD_DATA_STREAMS_BUCKET_DURATION=10    # Aggregation window in seconds
