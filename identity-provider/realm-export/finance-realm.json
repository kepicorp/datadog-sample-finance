      "realmRoles": [
        "finance-admin"
      ]
    },
    {
      "name": "auditors",
      "path": "/auditors",
      "realmRoles": [
        "finance-auditor"
      ]
    },
    {
      "name": "compliance",
      "path": "/compliance",
      "realmRoles": [
        "finance-compliance"
      ]
    }
  ],
