# ── KEYCLOAK ADMIN CREDENTIALS ───────────────────────────────────────────────
# These credentials protect the Keycloak admin console at http://localhost:8089
# Change these before any non-local deployment.

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── OIDC CLIENT SECRET ────────────────────────────────────────────────────────
# Secret used by gateway-api to validate tokens issued by Keycloak.
# Must match the value set on the 'finance-gateway' client in the realm export.
# Generate with: openssl rand -base64 32

KEYCLOAK_CLIENT_SECRET=REPLACE_WITH_SECRET

# ── DATADOG SSO SAML CONFIGURATION ───────────────────────────────────────────
# Set the correct ACS URL for your Datadog site region before configuring the
# 'datadog-saml' Keycloak client. Do NOT hardcode these in code — inject at runtime.
#
# US1 (default): https://app.datadoghq.com/account/saml/assertion
# EU:            https://app.datadoghq.eu/account/saml/assertion
# US3:           https://us3.datadoghq.com/account/saml/assertion
# US5:           https://us5.datadoghq.com/account/saml/assertion
# AP1:           https://ap1.datadoghq.com/account/saml/assertion
#
# DATADOG_SAML_ACS_URL=https://app.datadoghq.com/account/saml/assertion
# DATADOG_SAML_ENTITY_ID=https://app.datadoghq.com
#
# Keycloak IdP metadata URL (give this to Datadog during SAML setup):
# KEYCLOAK_IDP_METADATA_URL=http://localhost:8089/realms/finance/protocol/saml/descriptor

# ── KEYCLOAK ISSUER (used by gateway-api OIDC middleware) ────────────────────
# KEYCLOAK_ISSUER=http://localhost:8089/realms/finance
# KEYCLOAK_JWKS_URI=http://localhost:8089/realms/finance/protocol/openid-connect/certs
