# =============================================================================
# Finance Sample App — .gitignore
# =============================================================================

# ── Secrets & local config ───────────────────────────────────────────────────
# Never commit .env files containing real credentials.
# Copy .env.example to .env and fill in values locally.
.env
*.env.local

# ── Terraform ────────────────────────────────────────────────────────────────
# Provider binaries (100s of MB) — regenerated with `terraform init`
.terraform/

# State files may contain secrets (passwords, keys) — keep in remote backend
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Plan files capture the full desired state (potentially sensitive)
*.tfplan

# tfvars files may contain secrets — only *.tfvars.example are safe to commit
*.tfvars
!*.tfvars.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ── Java / Gradle ────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
target/
build/
.gradle/
out/
*.iml

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnp
.pnp.js
dist/

# ── Go ───────────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
vendor/

# ── IDEs & editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.code-workspace

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Docker ───────────────────────────────────────────────────────────────────
# Local override files (not committed — use docker-compose.base.yml or
# docker-compose.datadog.yml from the repo)
docker-compose.override.yml

# ── Kubernetes ───────────────────────────────────────────────────────────────
# Kubeconfig files may contain cluster credentials
kubeconfig
*.kubeconfig

# Generated EKS Kustomize overlay — regenerated by make deploy-k8s-eks
# Contains AWS account ID and region; do not commit with stale values
deploy/kubernetes/overlays/eks/kustomization.yaml

# ── Logs & temporary files ───────────────────────────────────────────────────
*.log
*.tmp
*.temp
.cache/

# ── Patch artifacts (generated by patch command) ─────────────────────────────
*.rej
*.orig
