# ── account-service environment variables ─────────────────────────────────
# Copy to .env for local development. Never commit .env to source control.
# For production: inject via K8s Secret or AWS Secrets Manager.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────
SERVER_PORT=8081

# ── ActiveMQ Artemis (JMS broker) ─────────────────────────────────────────
ACTIVEMQ_URL=tcp://localhost:61616
ACTIVEMQ_USER=admin
ACTIVEMQ_PASSWORD=changeme
# In docker-compose: ACTIVEMQ_URL=tcp://activemq-artemis:61616
# In Kubernetes:     ACTIVEMQ_URL=tcp://activemq-artemis.messaging.svc.cluster.local:61616

# ── PostgreSQL (Ledger database) ───────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/ledger
DB_USER=finance
DB_PASSWORD=changeme
# NEVER hardcode real passwords. Inject via:
#   Docker Compose secrets:  secrets: db_password
#   Kubernetes Secret:       valueFrom.secretKeyRef
#   AWS Secrets Manager:     use AWS SDK or EKS Pod Identity

# ── UNIFIED SERVICE TAGGING (required for Datadog correlation) ────────────
# https://docs.datadoghq.com/getting_started/tagging/unified_service_tagging/
# Set these before enabling any Datadog feature.
# They propagate to ALL telemetry: traces, logs, metrics, profiles.
DD_ENV=staging           # staging | production | dev
DD_SERVICE=account-service
DD_VERSION=1.0.0         # In CI: DD_VERSION=$(git rev-parse --short HEAD)
DD_AGENT_HOST=datadog-agent   # 'localhost' for local dev; 'datadog-agent' in docker-compose

# ── DATADOG INSTRUMENTATION — APM (Step 3) ────────────────────────────────
# Uncomment DD_LOGS_INJECTION after adding -javaagent to JAVA_TOOL_OPTIONS.
# Docs: https://docs.datadoghq.com/tracing/trace_collection/dd_libraries/java/
#
# DD_LOGS_INJECTION=true            # Injects dd.trace_id into every log line (Step 4)
# DD_TRACE_SAMPLE_RATE=1.0          # 1.0 = 100% sampling (dev). Reduce for production.
# DD_TRACE_ANALYTICS_ENABLED=true   # Enable App Analytics for this service

# ── DATADOG INSTRUMENTATION — Runtime Metrics (Step 6) ────────────────────
# Emits JVM metrics: heap, GC pause, thread count, class loading.
# Docs: https://docs.datadoghq.com/tracing/metrics/runtime_metrics/java/
#
# DD_RUNTIME_METRICS_ENABLED=true

# ── DATADOG INSTRUMENTATION — Continuous Profiler (Step 7) ────────────────
# Profiler is enabled via the JVM flag -Ddd.profiling.enabled=true.
# See JAVA_TOOL_OPTIONS below.
# Docs: https://docs.datadoghq.com/profiler/enabling/java/

# ── DATADOG INSTRUMENTATION — Data Streams Monitoring (Step 10) ───────────
# Tracks JMS pipeline latency: account-service → fraud.score.queue → fraud-detection
# Docs: https://docs.datadoghq.com/data_streams/java/
#
# DD_DATA_STREAMS_ENABLED=true
# DD_DATA_STREAMS_BUCKET_DURATION=10    # Aggregation window in seconds

# ── JAVA_TOOL_OPTIONS (JVM agent flags) ───────────────────────────────────
# Set this env var to activate the Datadog Java agent and all JVM-level features.
# The JVM picks up JAVA_TOOL_OPTIONS automatically — no code change required.
#
# Step 3  — -javaagent:/dd-java-agent.jar
# Step 4  — -Ddd.logs.injection=true
# Step 7  — -Ddd.profiling.enabled=true
# Step 10 — DD_DATA_STREAMS_ENABLED=true (env var, not a JVM flag)
#
# Docs: https://docs.datadoghq.com/tracing/trace_collection/dd_libraries/java/
#
# JAVA_TOOL_OPTIONS="\
#   -javaagent:/dd-java-agent.jar \
#   -Ddd.service=account-service \
#   -Ddd.env=${DD_ENV} \
#   -Ddd.version=${DD_VERSION} \
#   -Ddd.logs.injection=true \
#   -Ddd.runtime.metrics.enabled=true \
#   -Ddd.profiling.enabled=true \
#   -Ddd.trace.sample.rate=1.0 \
# "

# ── CUSTOM BUSINESS TAGS (add to every span — Step 5) ─────────────────────
# These are set programmatically via the Datadog Trace API (dd-trace-api).
# Document them here so all team members use consistent values.
# Finance span tags:
#   account.tier       → retail | premium | corporate
#   payment.currency   → EUR | USD | GBP
#   transaction.type   → payment | refund | transfer
#   db.instance        → postgres-ledger   (for DBM ↔ APM correlation)
#   messaging.destination → fraud.score.queue | alert.queue
#
# WARNING — High cardinality: never tag with raw account IDs, user IDs,
# transaction IDs, or message IDs as filtering dimensions.
# Use messaging.message_id for producer↔consumer correlation only.
# Docs: https://docs.datadoghq.com/tagging/assigning_tags/#defining-tags
