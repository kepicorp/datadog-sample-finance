# ── UNIFIED SERVICE TAGGING (required for Datadog correlation) ───────
# These three tags tie every signal — traces, logs, metrics, profiles —
# to the same service in the Datadog UI. Set them before enabling any
# instrumentation layer.
# Docs: https://docs.datadoghq.com/getting_started/tagging/unified_service_tagging/
DD_ENV=staging           # propagates to all telemetry: traces, logs, metrics, RUM
DD_SERVICE=gateway-api
DD_VERSION=1.0.0         # tie deployments to anomalies via Deployment Tracking

# ── DATADOG AGENT CONNECTION ─────────────────────────────────────────
# Points to the 'datadog-agent' Docker service (or K8s DaemonSet ClusterIP).
# Never use 'localhost' in containerised deployments — the Agent runs in
# a separate container and is not reachable on the loopback interface.
DD_AGENT_HOST=datadog-agent
DD_DOGSTATSD_PORT=8125
DD_TRACE_AGENT_PORT=8126

# ── APM SAMPLING (Step 3) ─────────────────────────────────────────────
# 1.0 = capture every trace. Reduce to 0.1–0.5 in high-volume production
# to control ingestion costs while keeping 100% for errors/outliers.
# Docs: https://docs.datadoghq.com/tracing/trace_pipeline/ingestion_controls/
# DD_TRACE_SAMPLE_RATE=1.0

# ── LOG CORRELATION (Step 4) ─────────────────────────────────────────
# Instructs dd-trace to inject dd.trace_id and dd.span_id into every log
# record so Log Management can pivot directly to the originating trace.
# Docs: https://docs.datadoghq.com/tracing/other_telemetry/connect_logs_and_traces/
# DD_LOGS_INJECTION=true

# ── RUNTIME METRICS (Step 6) ─────────────────────────────────────────
# Enables Python runtime metrics: GC collections, thread count, memory RSS.
# Surfaces in APM > Service > Runtime Metrics tab.
# Docs: https://docs.datadoghq.com/tracing/metrics/runtime_metrics/python/
# DD_RUNTIME_METRICS_ENABLED=true

# ── CONTINUOUS PROFILER (Step 7) ─────────────────────────────────────
# Enables CPU and wall-clock profiling. Correlates flamegraphs with APM traces.
# Docs: https://docs.datadoghq.com/profiler/enabling/python/
# DD_PROFILING_ENABLED=true

# ── CUSTOM BUSINESS TAGS ─────────────────────────────────────────────
# Finance-specific tags — add to every span and log for fast triage.
# These are set programmatically in main.py; document them here so
# operators know what to expect in the Datadog tag explorer.
#
# transaction.type   = payment | refund | transfer
# account.tier       = retail | premium | corporate
# payment.currency   = EUR | USD | GBP
# http.route         = /v1/payments/{id}   (normalised — never raw URL)

# ── SERVICE DISCOVERY ────────────────────────────────────────────────
PORT=8080
ACCOUNT_SERVICE_URL=http://account-service:8081
TRANSACTION_SERVICE_URL=http://transaction-service:8082
