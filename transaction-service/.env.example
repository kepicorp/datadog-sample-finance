# ── UNIFIED SERVICE TAGGING (required for Datadog correlation) ────────
# https://docs.datadoghq.com/getting_started/tagging/unified_service_tagging/
#
# These three tags must match across every telemetry signal — traces,
# logs, metrics, and RUM — for the correlation links in the Datadog UI
# to work (e.g. "View in APM" from a log line, Deployment Tracking,
# Service Catalog SLOs).
DD_ENV=staging
DD_SERVICE=transaction-service
DD_VERSION=1.0.0          # In CI: DD_VERSION=$(git rev-parse --short HEAD)

# ── DATADOG AGENT HOST ────────────────────────────────────────────────
# 'datadog-agent' resolves to the Agent container in Docker Compose and
# to the DaemonSet pod IP via the Downward API in Kubernetes.
# Use 'localhost' only for local bare-metal development.
DD_AGENT_HOST=datadog-agent

# ── APM / TRACING ─────────────────────────────────────────────────────
# DD_TRACE_SAMPLE_RATE=1.0    # 100 % trace capture — fine for staging.
#                             # In production, set 0.1–0.5 and use
#                             # priority sampling for critical paths.
# DD_LOGS_INJECTION=true      # Step 4 — inject trace_id into pino logs.
#                             # Requires logInjection:true in tracer init.

# ── RUNTIME METRICS ───────────────────────────────────────────────────
# DD_RUNTIME_METRICS_ENABLED=true   # Step 6 — emit Node.js V8/GC/
#                                   # event-loop metrics via DogStatsD.

# ── CONTINUOUS PROFILER ───────────────────────────────────────────────
# DD_PROFILING_ENABLED=true   # Step 7 — CPU + heap profiling.
#                             # Adds ~2 % CPU overhead; acceptable for
#                             # production Finance services.

# ── DATA STREAMS MONITORING ───────────────────────────────────────────
# DD_DATA_STREAMS_ENABLED=true         # Step 10 — enable DSM pipeline
#                                      # visibility on STOMP / JMS flows.
# DD_DATA_STREAMS_BUCKET_DURATION=10   # Aggregation window (seconds).
#                                      # Default 10 s is suitable for
#                                      # fraud-scoring SLA monitoring.

# ── CUSTOM BUSINESS TAGS ──────────────────────────────────────────────
# Finance-specific tags to add to every span and log for fast triage.
# Docs: https://docs.datadoghq.com/tagging/assigning_tags/
#
# DD_CUSTOM_TAG_REGION=eu-west-1
# DD_CUSTOM_TAG_TRANSACTION_TYPE=payment
# DD_CUSTOM_TAG_ACCOUNT_TIER=retail
#
# HIGH-CARDINALITY WARNING: never add transaction.id, account.id, or
# messaging.message_id as global tags — their value spaces are unbounded
# and will cause metric cardinality explosions in DogStatsD.
# Use these fields on individual spans and log records only.
# https://docs.datadoghq.com/tagging/assigning_tags/#defining-tags

# ── APPLICATION CONFIG ────────────────────────────────────────────────
PORT=8082
LOG_LEVEL=info             # pino log level: trace | debug | info | warn | error

# ── ACTIVEMQ ARTEMIS (JMS broker — STOMP protocol) ───────────────────
ACTIVEMQ_URL=stomp://activemq-artemis:61613
ACTIVEMQ_USER=guest
ACTIVEMQ_PASSWORD=guest    # Replace with a secret ref in K8s / AWS SM / GCP SM.
                           # NEVER commit real credentials to source control.

# ── POSTGRESQL (ledger database) ──────────────────────────────────────
POSTGRES_URL=postgresql://ledger_user:REPLACE_WITH_SECRET@postgres-ledger:5432/ledger
# Step 9 — Database Monitoring (DBM) is Agent-side only. No code change
# needed here. See deploy/docker/datadog-agent/conf.d/postgres.d/conf.yaml.
# Docs: https://docs.datadoghq.com/database_monitoring/setup_postgres/selfhosted/

# ── DATADOG API KEY ───────────────────────────────────────────────────
# DD_API_KEY is consumed by the Datadog Agent container, not this service.
# Set it on the Agent container only. See deploy/docker/docker-compose.yml.
# NEVER hardcode the API key in any application file or Docker image.
# Use AWS Secrets Manager, GCP Secret Manager, or a K8s Secret instead.
