# ── UNIFIED SERVICE TAGGING (required for Datadog correlation) ────────────────
# https://docs.datadoghq.com/getting_started/tagging/unified_service_tagging/
#
# These three tags propagate to ALL telemetry: traces, logs, metrics, profiles,
# and RUM sessions. They are the primary axes for filtering in every Datadog UI.
# Set identical values in Docker Compose, K8s ConfigMap, and CI/CD pipeline.

DD_ENV=staging
# Values: local | dev | staging | prod
# Tip: use the same value in all services deployed together so correlated traces
# share a single environment in APM > Services.

DD_SERVICE=notification-service
# Must match the Docker/K8s service name exactly (lowercase kebab-case).

DD_VERSION=1.0.0
# Tie deployments to anomalies via Deployment Tracking.
# In CI: DD_VERSION=$(git rev-parse --short HEAD)
# Docs: https://docs.datadoghq.com/tracing/deployment_tracking/

DD_AGENT_HOST=datadog-agent
# Docker Compose service name or K8s DaemonSet node IP.
# Use 'localhost' for local development without Docker.
# In Kubernetes: set to the node IP via the Downward API:
#   valueFrom:
#     fieldRef:
#       fieldPath: status.hostIP

# ── APPLICATION CONFIGURATION ─────────────────────────────────────────────────
ACTIVEMQ_URL=stomp://activemq-artemis:61613
# Format: stomp://<host>:<port> or stomp://<user>:<password>@<host>:<port>
# Default STOMP port for ActiveMQ Artemis is 61613.

# ── DATADOG APM ───────────────────────────────────────────────────────────────
# Docs: https://docs.datadoghq.com/tracing/trace_collection/dd_libraries/go/
#
# DD_TRACE_AGENT_PORT=8126
# DD_TRACE_SAMPLE_RATE=1.0
# Sampling: 1.0 = 100% — appropriate for low-traffic notification workloads.
# Reduce to 0.1 for high-throughput services in production.
#
# DD_LOGS_INJECTION=true
# When set, dd-trace-go automatically injects dd.trace_id and dd.span_id into
# log output so Log Management can correlate logs with APM traces.
# Docs: https://docs.datadoghq.com/tracing/other_telemetry/connect_logs_and_traces/go/

# ── DATADOG RUNTIME METRICS ───────────────────────────────────────────────────
# DD_RUNTIME_METRICS_ENABLED=true
# Emits Go runtime metrics: goroutine count, heap allocation, GC pause time,
# memory stats. Visible in APM > Services > notification-service > Runtime Metrics.
# Docs: https://docs.datadoghq.com/tracing/metrics/runtime_metrics/go/

# ── DATA STREAMS MONITORING (DSM) ─────────────────────────────────────────────
# Provides end-to-end pipeline visibility: consumer lag, end-to-end latency,
# and queue depth trends for the payment → fraud → notification JMS chain.
# Docs: https://docs.datadoghq.com/data_streams/go/
#
# DD_DATA_STREAMS_ENABLED=true
# DD_DATA_STREAMS_BUCKET_DURATION=10
# Aggregation window in seconds. Default 10s is appropriate for most workloads.

# ── CONTINUOUS PROFILER ───────────────────────────────────────────────────────
# Docs: https://docs.datadoghq.com/profiler/enabling/go/
#
# DD_PROFILING_ENABLED=true
# Collects CPU, heap, goroutine, and mutex profiles. Correlate flame graphs
# with slow alert.send traces to identify notification dispatch bottlenecks.

# ── CUSTOM BUSINESS TAGS ──────────────────────────────────────────────────────
# Finance-specific: add to every span and log line for fast incident triage.
# Docs: https://docs.datadoghq.com/tagging/assigning_tags/
#
# DD_CUSTOM_TAG_REGION=eu-west-1
# DD_CUSTOM_TAG_NOTIFICATION_CHANNEL=email
# DD_CUSTOM_TAG_ACCOUNT_TIER=premium
#
# ⚠️  HIGH CARDINALITY WARNING:
# Do NOT use raw account numbers, IBANs, card numbers, message IDs, or user IDs
# as tag values — these create unbounded cardinality and degrade query performance.
# Always bucket or anonymise before tagging.
# Ref: https://docs.datadoghq.com/tagging/assigning_tags/#defining-tags
